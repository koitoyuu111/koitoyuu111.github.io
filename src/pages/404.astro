---
import Layout from "../layouts/Layout.astro";
import { url } from "../utils/url-utils";
---

<Layout title="404 - 页面未找到" description="抱歉，您访问的页面不存在。">
	<div class="flex items-center justify-center min-h-[60vh] px-4">
		<div class="text-center">
			<div class="text-[8rem] md:text-[10rem] font-bold leading-none text-[var(--primary)] opacity-30 select-none">
				404
			</div>
			<h1 class="text-2xl md:text-3xl font-bold text-black/80 dark:text-white/80 mt-4 mb-2">
				页面未找到
			</h1>
			<p class="text-black/50 dark:text-white/50 mb-8 max-w-md mx-auto leading-relaxed">
				抱歉，您访问的页面不存在或已被移动。<br />
				请检查 URL 是否正确，或返回首页继续浏览。
			</p>
			<div class="flex items-center justify-center gap-4">
				<a href={url("/")} class="btn-regular-dark px-6 py-2.5 rounded-lg font-medium text-sm">
					返回首页
				</a>
				<a href={url("/archive/")} class="btn-card px-6 py-2.5 rounded-lg font-medium text-sm text-black/75 dark:text-white/75">
					文章归档
				</a>
			</div>
		</div>
	</div>
</Layout>
